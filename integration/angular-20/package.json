{
  "name": "carbideui-integration-angular20",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "start": "ng serve",
    "build": "ng build --configuration production",
    "build:dev": "ng build --configuration development",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "lint": "ng lint --max-warnings=0 2>/dev/null || echo 'ESLint not configured in integration project'",
    "test": "ng test --no-watch --no-progress --browsers=ChromeHeadless 2>/dev/null || echo 'No unit tests in integration project'",
    "verify": "npm run typecheck && npm run build",
    "verify:full": "npm run typecheck && npm run build && node scripts/verify-bundle-size.mjs"
  },
  "dependencies": {
    "@angular/animations": "^20.0.0",
    "@angular/common": "^20.0.0",
    "@angular/compiler": "^20.0.0",
    "@angular/core": "^20.0.0",
    "@angular/forms": "^20.0.0",
    "@angular/platform-browser": "^20.0.0",
    "@angular/platform-browser-dynamic": "^20.0.0",
    "@angular/router": "^20.0.0",
    "@assistanz/carbideui": "file:../../dist/carbideui",
    "@carbon/charts": "^1.27.3",
    "@carbon/styles": "^1.102.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "^0.15.0"
  },
  "devDependencies": {
    "@angular/build": "^20.0.0",
    "@angular/cli": "^20.0.0",
    "@angular/compiler-cli": "^20.0.0",
    "typescript": "~5.8.0"
  }
}
